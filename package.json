{
  "name": "alloy",
  "displayName": "Alloy - AI Code Reviewer",
  "description": "AI-powered code review agent for VS Code",
  "version": "0.1.0",
  "icon": "resources/icon.png",
  "publisher": "alloy",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18.0.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "title": "Alloy",
      "properties": {
        "alloy.reviewOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically review code on save with a 2-second debounce"
        },
        "alloy.provider": {
          "type": "string",
          "enum": ["groq", "gemini", "openaiCompatible", "ollama"],
          "default": "groq",
          "description": "LLM provider Alloy uses for reviews"
        },
        "alloy.model": {
          "type": "string",
          "default": "",
          "description": "Model name for the selected provider. Leave empty to use Alloy's default."
        },
        "alloy.reviewMode": {
          "type": "string",
          "enum": ["fast", "deep", "architecture"],
          "default": "fast",
          "description": "Review depth and focus"
        },
        "alloy.maxDiffLines": {
          "type": "number",
          "default": 600,
          "description": "Skip reviews for diffs larger than this many lines"
        },
        "alloy.maxFilesPerReview": {
          "type": "number",
          "default": 12,
          "description": "Maximum changed files reviewed by Alloy: Review All Changed Files"
        },
        "alloy.skipPaths": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Glob patterns Alloy should skip"
        },
        "alloy.enabledCategories": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["security", "logic", "quality", "performance", "test"]
          },
          "default": ["security", "logic", "quality", "performance", "test"],
          "description": "Finding categories Alloy should show"
        },
        "alloy.enabledSeverities": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["error", "warning", "info"]
          },
          "default": ["error", "warning", "info"],
          "description": "Finding severities Alloy should show"
        },
        "alloy.debounceMs": {
          "type": "number",
          "default": 2000,
          "description": "Debounce duration for review on save"
        }
      }
    },
    "commands": [
      {
        "command": "alloy.openMenu",
        "title": "Alloy",
        "icon": {
          "light": "resources/icon.png",
          "dark": "resources/icon.png"
        }
      },
      {
        "command": "alloy.setup",
        "title": "Alloy: Setup"
      },
      {
        "command": "alloy.reviewCurrentFile",
        "title": "Alloy: Review Current File",
        "icon": {
          "light": "resources/icon.png",
          "dark": "resources/icon.png"
        }
      },
      {
        "command": "alloy.reviewAllChangedFiles",
        "title": "Alloy: Review All Changed Files"
      },
      {
        "command": "alloy.clearFindings",
        "title": "Alloy: Clear Findings"
      },
      {
        "command": "reviewbot.reviewCurrentFile",
        "title": "ReviewBot: Review Current File (Legacy)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "alloyFindings",
          "name": "Alloy Findings"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "alloy.openMenu",
          "group": "navigation",
          "when": "editorLangId =~ /typescript|javascript/"
        }
      ]
    }
  },
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --config jest.config.js --watch"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@langchain/langgraph": "^1.3.2",
    "simple-git": "^3.22.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.26.9"
  }
}
