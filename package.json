{
  "name": "alloy",
  "displayName": "Alloy - AI Code Reviewer",
  "description": "AI-powered code review agent for VS Code",
  "version": "0.1.0",
  "icon": "resources/icon.png",
  "publisher": "alloy",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18.0.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "title": "Alloy",
      "properties": {
        "alloy.reviewOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically review code on save with a 2-second debounce"
        },
        "alloy.provider": {
          "type": "string",
          "enum": ["groq", "gemini", "openaiCompatible", "ollama"],
          "default": "groq",
          "description": "LLM provider Alloy uses for reviews"
        },
        "alloy.model": {
          "type": "string",
          "default": "",
          "description": "Model name for the selected provider. Leave empty to use Alloy's default."
        },
        "alloy.reviewMode": {
          "type": "string",
          "enum": ["fast", "deep", "architecture"],
          "default": "fast",
          "description": "Review depth and focus"
        },
        "alloy.maxDiffLines": {
          "type": "number",
          "default": 600,
          "description": "Skip reviews for diffs larger than this many lines"
        },
        "alloy.maxFilesPerReview": {
          "type": "number",
          "default": 12,
          "description": "Maximum changed files reviewed by Alloy: Review All Changed Files"
        },
        "alloy.skipPaths": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Glob patterns Alloy should skip"
        },
        "alloy.enabledCategories": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["security", "logic", "quality", "performance", "test"]
          },
          "default": ["security", "logic", "quality", "performance", "test"],
          "description": "Finding categories Alloy should show"
        },
        "alloy.enabledSeverities": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["error", "warning", "info"]
          },
          "default": ["error", "warning", "info"],
          "description": "Finding severities Alloy should show"
        },
        "alloy.debounceMs": {
          "type": "number",
          "default": 2000,
          "description": "Debounce duration for review on save"
        },
        "alloy.findingsGroupBy": {
          "type": "string",
          "enum": ["file", "severity", "category"],
          "default": "file",
          "description": "How to group findings in the Alloy Findings tree view"
        }
      }
    },
    "commands": [
      {
        "command": "alloy.openMenu",
        "title": "Alloy",
        "icon": {
          "light": "resources/icon-light.png",
          "dark": "resources/icon-dark.png"
        }
      },
      {
        "command": "alloy.setup",
        "title": "Alloy: Setup"
      },
      {
        "command": "alloy.reviewCurrentFile",
        "title": "Alloy: Review Current File",
        "icon": {
          "light": "resources/icon-light.png",
          "dark": "resources/icon-dark.png"
        }
      },
      {
        "command": "alloy.reviewAllChangedFiles",
        "title": "Alloy: Review All Changed Files"
      },
      {
        "command": "alloy.clearFindings",
        "title": "Alloy: Clear Findings"
      },
      {
        "command": "alloy.dismissFinding",
        "title": "Alloy: Dismiss Finding"
      },
      {
        "command": "alloy.dismissAllInFile",
        "title": "Alloy: Dismiss All in File"
      },
      {
        "command": "alloy.copyFinding",
        "title": "Alloy: Copy Finding"
      },
      {
        "command": "alloy.groupByFile",
        "title": "Group by File"
      },
      {
        "command": "alloy.groupBySeverity",
        "title": "Group by Severity"
      },
      {
        "command": "alloy.groupByCategory",
        "title": "Group by Category"
      },
      {
        "command": "alloy.filterFindings",
        "title": "Alloy: Filter Findings",
        "icon": "$(filter)"
      },
      {
        "command": "alloy.generatePRDescription",
        "title": "Alloy: Generate PR Description"
      },
      {
        "command": "alloy.openRulesFile",
        "title": "Alloy: Open Custom Rules File"
      },
      {
        "command": "alloy.exportFindingsJSON",
        "title": "Alloy: Export Findings (JSON)"
      },
      {
        "command": "alloy.exportFindingsMarkdown",
        "title": "Alloy: Export Findings (Markdown)"
      },
      {
        "command": "alloy.reviewStagedCurrentFile",
        "title": "Alloy: Review Staged Changes (Current File)"
      },
      {
        "command": "alloy.reviewAllStagedFiles",
        "title": "Alloy: Review All Staged Files"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "alloyFindings",
          "name": "Alloy Findings"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "alloy.openMenu",
          "group": "navigation",
          "when": "editorLangId =~ /typescript|javascript|python|go|rust|java|csharp|php|ruby|vue|svelte|kotlin|swift|c|cpp/"
        }
      ],
      "view/title": [
        {
          "command": "alloy.filterFindings",
          "when": "view == alloyFindings",
          "group": "navigation"
        },
        {
          "command": "alloy.groupByFile",
          "when": "view == alloyFindings",
          "group": "navigation"
        },
        {
          "command": "alloy.groupBySeverity",
          "when": "view == alloyFindings",
          "group": "navigation"
        },
        {
          "command": "alloy.groupByCategory",
          "when": "view == alloyFindings",
          "group": "navigation"
        },
        {
          "command": "alloy.clearFindings",
          "when": "view == alloyFindings",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "alloy.dismissFinding",
          "when": "view == alloyFindings && viewItem == alloyFinding",
          "group": "alloy@1"
        },
        {
          "command": "alloy.copyFinding",
          "when": "view == alloyFindings && viewItem == alloyFinding",
          "group": "alloy@2"
        },
        {
          "command": "alloy.dismissAllInFile",
          "when": "view == alloyFindings && viewItem == alloyFile",
          "group": "alloy@1"
        }
      ]
    }
  },
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --config jest.config.js --watch"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@langchain/langgraph": "^1.3.2",
    "simple-git": "^3.22.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.26.9"
  }
}
