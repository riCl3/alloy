{
  "name": "alloy",
  "displayName": "Alloy - AI Code Reviewer",
  "description": "AI-powered code review agent for VS Code",
  "version": "0.1.0",
  "icon": "resources/icon.png",
  "publisher": "alloy",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18.0.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:reviewbot.reviewCurrentFile"
  ],
  "contributes": {
    "commands": [
      {
        "command": "reviewbot.reviewCurrentFile",
        "title": "ReviewBot: Review Current File",
        "icon": {
          "light": "resources/icon.png",
          "dark": "resources/icon.png"
        }
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "reviewbot.reviewCurrentFile",
          "group": "navigation",
          "when": "editorLangId =~ /typescript|javascript|python/"
        }
      ]
    }
  },
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --config jest.config.js --watch"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@langchain/langgraph": "^1.3.2",
    "simple-git": "^3.22.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.26.9"
  }
}
